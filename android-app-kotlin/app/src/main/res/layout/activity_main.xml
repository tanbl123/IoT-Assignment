<?xml version="1.0" encoding="utf-8"?>
<!-- Caregiver dashboard layout: status line, live HR chart, history area. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: —   HR: —   SpO₂: —"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="12dp" />

    <!-- Live heart-rate chart (MPAndroidChart) -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/hrChart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fall history"
        android:textStyle="bold"
        android:paddingTop="12dp" />

    <!-- TODO: replace with a RecyclerView bound to falls/ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/historyList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
